---
import { Image } from "astro:assets";
import { site } from "../data/site";
import portrait from "../assets/photo-arnaud.jpg";

const { about } = site;
---

<section id="a-propos">
  <div class="container">
    <div class="about">
      <div class="portrait">
        <Image
          src={portrait}
          alt={`${site.name}, psychologue`}
          widths={[300, 500, 700]}
          sizes="(max-width: 820px) 100vw, 33vw"
          loading="lazy"
        />
      </div>
      <div>
        <h2>{about.heading}</h2>
        {about.paragraphs.map((p) => <p>{p}</p>)}

        <h3 style="margin-top:1.4em">Parcours</h3>
        <ul class="timeline">
          {about.parcours.map((item) => (
            <li>
              <span class="year">{item.year}</span> — {item.text}
            </li>
          ))}
        </ul>

        <div class="callout">
          <h3>{about.callout.title}</h3>
          <p style="margin:0">{about.callout.text}</p>
        </div>
      </div>
    </div>
  </div>
</section>
